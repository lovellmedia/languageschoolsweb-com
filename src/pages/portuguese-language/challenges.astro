      <tr>
        <th>Term</th>
        <th>Brazilian Meaning</th>
        <th>European Meaning</th>
        <th>Risk Level</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><em>rapariga</em></td>
        <td>Young woman (neutral)</td>
        <td>Prostitute (vulgar)</td>
        <td>High</td>
      </tr>
      <tr>
        <td><em>bicha</em></td>
        <td>Line/queue (slang)</td>
