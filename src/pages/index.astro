---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Language Schools Web - Portuguese Language Studies";
const description = "Comprehensive resource for Portuguese language studies, exploring the fascinating differences between Brazilian and European Portuguese variants, history, grammar, and cultural contexts.";

const pillarCards = [
  {
    title: "Overview",
    description: "Introduction to Brazilian and European Portuguese differences, key distinctions at a glance, and mutual intelligibility factors.",
    icon: "📋",
    href: "/portuguese-variants/",
    color: "#004d40"
  },
  {
    title: "History & Evolution",
    description: "Colonial separation, linguistic drift, indigenous and African influences, and the 1990 Orthographic Agreement.",
    icon: "📜",
    href: "/portuguese-variants/history/",
    color: "#00695c"
  },
  {
    title: "Technical Deep-Dive",
    description: "Grammatical differences, pronunciation systems, vocabulary divergences, and formal vs. informal registers.",
    icon: "⚙️",
    href: "/portuguese-variants/technical-deep-dive/",
    color: "#00796b"
  },
  {
    title: "Ontology & Knowledge Base",
    description: "Comprehensive vocabulary comparison tables, grammatical feature matrices, and regional sub-variant classification.",
    icon: "🗂️",
    href: "/portuguese-variants/ontology/",
    color: "#00897b"
  },
  {
    title: "Current Trends & Future",
    description: "Globalization impact, media influence, technology terminology, and youth language evolution.",
    icon: "📈",
    href: "/portuguese-variants/trends/",
    color: "#009688"
  },
  {
    title: "Tools & Resources",
    description: "Interactive vocabulary translators, pronunciation comparison tools, and text variant analyzers.",
    icon: "🛠️",
    href: "/portuguese-variants/tools/",
    color: "#26a69a"
  },
  {
    title: "Challenges & Solutions",
    description: "Understanding rapid speech, adapting to informal registers, professional communication, and exam considerations.",
    icon: "🎯",
    href: "/portuguese-variants/challenges/",
    color: "#4db6ac"
  }
];

const stats = [
  { value: "250M+", label: "Portuguese Speakers" },
  { value: "10", label: "Official Countries" },
  { value: "4", label: "Continents" },
  { value: "9", label: "CPLP Members" }
];
---

<BaseLayout title={title} description={description}>
  <div class="homepage">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-container">
        <div class="hero-content">
          <h1 class="hero-title">
            Portuguese Language Studies
            <span class="hero-subtitle">Brazilian vs. European Variants</span>
          </h1>
          <p class="hero-description">
            Explore the rich linguistic landscape of Portuguese across four continents. 
            Discover the fascinating differences between Brazilian and European Portuguese, 
            from colonial origins to modern-day usage in business, media, and daily life.
          </p>
          <div class="hero-actions">
            <a href="/portuguese-variants/" class="btn-primary">Start Exploring</a>
            <a href="/portuguese-variants/tools/" class="btn-secondary">Try Our Tools</a>
          </div>
        </div>
        <div class="hero-stats">
          {stats.map(stat => (
            <div class="stat-card">
              <span class="stat-value">{stat.value}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pillar Cards Section -->
    <section class="pillars-section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Explore Portuguese Variants</h2>
          <p class="section-description">
            Seven comprehensive pillars covering every aspect of Brazilian and European Portuguese comparison
          </p>
        </div>
        
        <div class="pillars-grid">
          {pillarCards.map((card, index) => (
            <a href={card.href} class="pillar-card" style={`--card-color: ${card.color}`}>
              <div class="pillar-icon">{card.icon}</div>
              <h3 class="pillar-title">{card.title}</h3>
              <p class="pillar-description">{card.description}</p>
              <span class="pillar-link">Learn more →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured Content Section -->
    <section class="featured-section">
      <div class="container">
        <div class="featured-grid">
          <div class="featured-content">
            <h2>Why Study Portuguese Variants?</h2>
            <p>
              Portuguese is the sixth most spoken language in the world, with over 250 million speakers 
              across four continents. However, learners often face a crucial decision: should they study 
              Brazilian or European Portuguese?
            </p>
            <p>
              While these variants remain mutually intelligible, significant differences in pronunciation, 
              vocabulary, and grammar can impact communication effectiveness. Understanding these distinctions 
              is essential for:
            </p>
            <ul>
              <li>Business professionals working with Lusophone markets</li>
              <li>Students preparing for CAPLE or CELPE-Bras exams</li>
              <li>Travelers planning extended stays in Portuguese-speaking countries</li>
              <li>Translators and interpreters seeking specialization</li>
              <li>Language enthusiasts exploring Romance language diversity</li>
            </ul>
            <a href="/portuguese-variants/" class="btn-primary">Begin Your Journey</a>
          </div>
          
          <div class="featured-highlights">
            <div class="highlight-box">
              <h4>🌍 Global Reach</h4>
              <p>Portuguese is the official language of 10 countries across Europe, South America, Africa, and Asia.</p>
            </div>
            <div class="highlight-box">
              <h4>📚 Rich Heritage</h4>
              <p>From medieval Galician-Portuguese poetry to modern Brazilian literature, the language carries centuries of cultural expression.</p>
            </div>
            <div class="highlight-box">
              <h4>💼 Business Advantage</h4>
              <p>Brazil's economy and Portugal's EU membership make Portuguese increasingly valuable in global commerce.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2>Ready to Master Portuguese?</h2>
          <p>
            Start with our comprehensive Overview, dive into the technical details, 
            or test your knowledge with our interactive tools.
          </p>
          <div class="cta-actions">
            <a href="/portuguese-variants/" class="btn-primary btn-large">Explore the Guide</a>
            <a href="/portuguese-variants/tools/" class="btn-secondary btn-large">Use the Tools</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    background: linear-gradient(135deg, #004d40 0%, #00695c 50%, #00796b 100%);
    color: white;
    padding: 5rem 0;
  }
  
  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: white;
  }
  
  .hero-subtitle {
    display: block;
    font-size: 1.5rem;
    font-weight: 400;
    opacity: 0.9;
    margin-top: 0.5rem;
  }
  
  .hero-description {
    font-size: 1.125rem;
    line-height: 1.7;
    opacity: 0.9;
    margin-bottom: 2rem;
  }
  
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: white;
    color: #004d40;
    padding: 0.875rem 1.75rem;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    border: 2px solid white;
  }
  
  .btn-primary:hover {
    background: transparent;
    color: white;
  }
  
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: white;
    padding: 0.875rem 1.75rem;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    border: 2px solid rgba(255,255,255,0.5);
  }
  
  .btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: white;
  }
  
  .btn-large {
    padding: 1rem 2rem;
    font-size: 1.125rem;
  }
  
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  
  .stat-card {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    padding: 1.5rem;
    border-radius: 0.75rem;
    text-align: center;
    border: 1px solid rgba(255,255,255,0.2);
  }
  
  .stat-value {
    display: block;
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
  }
  
  .stat-label {
    display: block;
    font-size: 0.875rem;
    opacity: 0.8;
    margin-top: 0.25rem;
  }
  
  /* Pillars Section */
  .pillars-section {
    padding: 5rem 0;
    background: #f9fafb;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .section-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 1rem;
  }
  
  .section-description {
    font-size: 1.125rem;
    color: #6b7280;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  
  .pillar-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.5rem;
    text-decoration: none;
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    border-top: 4px solid var(--card-color);
  }
  
  .pillar-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -8px rgba(0,0,0,0.15);
    border-color: var(--card-color);
  }
  
  .pillar-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .pillar-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 0.5rem;
  }
  
  .pillar-description {
    font-size: 0.9375rem;
    color: #6b7280;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1rem;
  }
  
  .pillar-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--card-color);
  }
  
  .pillar-card:hover .pillar-link {
    text-decoration: underline;
  }
  
  /* Featured Section */
  .featured-section {
    padding: 5rem 0;
    background: white;
  }
  
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  
  .featured-content h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 1.5rem;
  }
  
  .featured-content p {
    color: #4b5563;
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  
  .featured-content ul {
    color: #4b5563;
    margin-bottom: 2rem;
    padding-left: 1.5rem;
  }
  
  .featured-content li {
    margin-bottom: 0.5rem;
  }
  
  .featured-highlights {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .highlight-box {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.5rem;
  }
  
  .highlight-box h4 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #111827;
    margin-bottom: 0.5rem;
  }
  
  .highlight-box p {
    font-size: 0.9375rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }
  
  /* CTA Section */
  .cta-section {
    padding: 5rem 0;
    background: #f9fafb;
  }
  
  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .cta-content h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 1rem;
  }
  
  .cta-content p {
    font-size: 1.125rem;
    color: #6b7280;
    margin-bottom: 2rem;
  }
  
  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .cta-actions .btn-primary {
    background: #004d40;
    color: white;
    border-color: #004d40;
  }
  
  .cta-actions .btn-primary:hover {
    background: #00695c;
    border-color: #00695c;
  }
  
  .cta-actions .btn-secondary {
    background: white;
    color: #374151;
    border-color: #d1d5db;
  }
  
  .cta-actions .btn-secondary:hover {
    background: #f3f4f6;
    border-color: #9ca3af;
  }
  
  /* Responsive */
  @media (max-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }
    
    .hero-title {
      font-size: 2.5rem;
    }
    
    .hero-stats {
      max-width: 500px;
      margin: 0 auto;
    }
    
    .featured-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
  
  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0;
    }
    
    .hero-title {
      font-size: 2rem;
    }
    
    .hero-subtitle {
      font-size: 1.25rem;
    }
    
    .hero-stats {
      grid-template-columns: 1fr 1fr;
    }
    
    .stat-value {
      font-size: 1.75rem;
    }
    
    .section-title {
      font-size: 1.75rem;
    }
    
    .pillars-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
