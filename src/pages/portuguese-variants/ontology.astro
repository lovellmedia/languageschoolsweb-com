      </tr>
      <tr>
        <td>Reflexive passive</td>
        <td>Declining; analytic preferred</td>
        <td>Productive and common</td>
        <td>Syntactic</td>
      </tr>
      <tr>
        <td>Future subjunctive</td>
        <td>Maintained in formal registers</td>
        <td>Fully productive</td>
        <td>Morphological</td>
      </tr>
      <tr>
