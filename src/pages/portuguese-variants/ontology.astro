---
import TopicLayout from '../../layouts/TopicLayout.astro';

const title = "Ontology & Knowledge Base: Portuguese Language Structure";
const description = "Comprehensive glossary, taxonomies, and structured knowledge resources for Brazilian and European Portuguese. Explore vocabulary databases, grammatical feature matrices, and terminology systems.";

const relatedTopics = [
  { name: "Overview", url: "/portuguese-variants/" },
  { name: "History & Evolution", url: "/portuguese-variants/history/" },
  { name: "Technical Deep-Dive", url: "/portuguese-variants/technical-deep-dive/" },
  { name: "Current Trends", url: "/portuguese-variants/trends/" },
  { name: "Tools & Resources", url: "/portuguese-variants/tools/" },
  { name: "Challenges & Solutions", url: "/portuguese-variants/challenges/" }
];

