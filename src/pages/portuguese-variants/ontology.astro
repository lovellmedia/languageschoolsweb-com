      </tr>
      <tr>
        <td>2nd person address</td>
        <td>Você generalized</td>
        <td>Tu/Você distinction maintained</td>
        <td>Morphosyntactic</td>
      </tr>
      <tr>
        <td>Object clitic system</td>
        <td>Simplified; "te/o/a" predominant</td>
        <td>Full system maintained</td>
        <td>Morphological</td>
      </tr>
      <tr>
        <td>Possessive position</td>
