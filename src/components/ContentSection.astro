---
export interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<section class="content-section">
  {title && <h2 class="section-title">{title}</h2>}
  <div class="section-content">
    <slot />
  </div>
</section>

<style>
  .content-section {
    margin-bottom: 2.5rem;
  }
  
  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 1rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }
  
  .section-content {
    color: #374151;
    line-height: 1.7;
  }
  
  .section-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin: 2rem 0 1rem 0;
  }
  
  .section-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1f2937;
    margin: 1.5rem 0 0.75rem 0;
  }
  
  .section-content :global(h4) {
    font-size: 1.125rem;
    font-weight: 600;
    color: #374151;
    margin: 1.25rem 0 0.5rem 0;
  }
  
  .section-content :global(p) {
    margin: 0 0 1rem 0;
  }
  
  .section-content :global(ul), 
  .section-content :global(ol) {
    margin: 0 0 1rem 0;
    padding-left: 1.5rem;
  }
  
  .section-content :global(li) {
    margin-bottom: 0.5rem;
  }
  
  .section-content :global(blockquote) {
    border-left: 4px solid #004d40;
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #4b5563;
  }
  
  .section-content :global(a) {
    color: #004d40;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  
  .section-content :global(a:hover) {
    color: #00695c;
  }
  
  .section-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }
  
  .section-content :global(th),
  .section-content :global(td) {
    padding: 0.75rem;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
  }
  
  .section-content :global(th) {
    font-weight: 600;
    background: #f9fafb;
    color: #374151;
  }
  
  .section-content :global(tr:hover) {
    background: #f9fafb;
  }
</style>
