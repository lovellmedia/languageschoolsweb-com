---
export interface Props {
  relatedTopics?: Array<{name: string; url: string}>;
  keyPoints?: string[];
}

const { relatedTopics = [], keyPoints = [] } = Astro.props;
---

<aside class="sidebar">
  {keyPoints.length > 0 && (
    <div class="sidebar-section">
      <h4 class="sidebar-title">Key Points</h4>
      <ul class="key-points-list">
        {keyPoints.map((point) => (
          <li>{point}</li>
        ))}
      </ul>
    </div>
  )}
  
  {relatedTopics.length > 0 && (
    <div class="sidebar-section">
      <h4 class="sidebar-title">Related Topics</h4>
      <ul class="related-topics-list">
        {relatedTopics.map((topic) => (
          <li>
            <a href={topic.url}>{topic.name}</a>
          </li>
        ))}
      </ul>
    </div>
  )}
  
  <div class="sidebar-section">
    <h4 class="sidebar-title">Quick Facts</h4>
    <div class="quick-facts">
      <div class="fact-item">
        <span class="fact-label">Speakers</span>
        <span class="fact-value">250M+ Worldwide</span>
      </div>
      <div class="fact-item">
        <span class="fact-label">Countries</span>
        <span class="fact-value">10 Official</span>
      </div>
      <div class="fact-item">
        <span class="fact-label">Continents</span>
        <span class="fact-value">4 (EU, SA, AF, AS)</span>
      </div>
      <div class="fact-item">
        <span class="fact-label">CPLP Members</span>
        <span class="fact-value">9 Countries</span>
      </div>
    </div>
  </div>
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .sidebar-section {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 1.25rem;
  }
  
  .sidebar-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
    margin: 0 0 0.75rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e5e7eb;
  }
  
  .key-points-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .key-points-list li {
    font-size: 0.875rem;
    color: #374151;
    padding-left: 1rem;
    position: relative;
  }
  
  .key-points-list li::before {
    content: "•";
    color: #004d40;
    position: absolute;
    left: 0;
    font-weight: bold;
  }
  
  .related-topics-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .related-topics-list a {
    font-size: 0.875rem;
    color: #004d40;
    text-decoration: none;
    display: block;
    padding: 0.375rem 0;
    transition: color 0.2s;
  }
  
  .related-topics-list a:hover {
    color: #00695c;
    text-decoration: underline;
  }
  
  .quick-facts {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .fact-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid #e5e7eb;
  }
  
  .fact-item:last-child {
    border-bottom: none;
  }
  
  .fact-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: #6b7280;
    text-transform: uppercase;
  }
  
  .fact-value {
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
  }
</style>
